flowchart TD
    classDef actor       fill:#dae8fc,stroke:#6c8ebf,color:#000,font-weight:bold
    classDef client      fill:#ffe6cc,stroke:#d6b656,color:#000,font-weight:bold
    classDef service     fill:#e1d5e7,stroke:#9673a6,color:#000,font-weight:bold
    classDef database    fill:#d5e8d4,stroke:#82b366,color:#000,font-weight:bold
    classDef gateway     fill:#fff2cc,stroke:#d6b656,color:#000,font-weight:bold
    classDef errorNode   fill:#f8cecc,stroke:#b85450,color:#000,font-weight:bold
    classDef successNode fill:#d5e8d4,stroke:#82b366,color:#000,font-weight:bold

    subgraph "🔐 FLUJO A: Edición de Perfil & Cambio de Contraseña (Autenticado)"
        Start_A([🟢 Inicio: Usuario Autenticado]):::successNode
        AccederPerfil["🖥️ Acceder a /dashboard/perfil"]:::actor
        CargarDatos["🖥️ Solicitar perfil al entrar"]:::client
        ObtenerDatos["⚙️ PerfilesRepository.getProfileByUserId()"]:::service
        RellenarForm["🖥️ Prellenar formulario con datos vigentes"]:::client
        
        %% Elección de Acción
        Interaccion{"Seleccionar acción"}:::gateway
        
        %% Acción 1: Modificar datos
        ModDatos["📝 Modificar Nombre, Cargo o Teléfono"]:::actor
        ClickGuardar["🖥️ Clic en 'Guardar cambios'"]:::actor
        ValidadorMail{"¿Nuevo correo?"}:::gateway
        ChkDuplicado{"¿Correo ya existe\nen otro perfil?"}:::gateway
        ErrorDupMail["⚠️ Mostrar error: Correo ya registrado"]:::errorNode
        UpdateDb["⚙️ PerfilesRepository.updateProfile()"]:::service
        TriggerAudit[("🗄️ PostgreSQL Trigger: Registrar historial en historial_perfiles")]:::database
        ShowSuccessProfile["🎉 Mostrar alerta: Cambios guardados"]:::successNode

        %% Acción 2: Cambiar contraseña
        ModPass["📝 Llenar Contraseña actual, Nueva y Confirmar"]:::actor
        ClickUpdatePass["🖥️ Clic en 'Actualizar contraseña'"]:::actor
        VerifyCurrent{"Re-autenticar con\ncontraseña actual"}:::gateway
        ErrorCurrentPass["⚠️ Mostrar error: Contraseña actual incorrecta"]:::errorNode
        UpdateAuthPass["⚙️ Supabase Auth: updateUser(password)"]:::service
        ShowSuccessPass["🎉 Mostrar alerta: Contraseña actualizada"]:::successNode
    end

    subgraph "📧 FLUJO B: Recuperación de Contraseña Autónoma (No Autenticado)"
        Start_B([🟢 Inicio: Pantalla de Login]):::successNode
        ClickOlvide["🖥️ Clic en ¿Olvidaste tu contraseña?"]:::actor
        AccederRecuperar["🖥️ Ir a /recuperar"]:::client
        IngresarEmail["📝 Ingresar correo electrónico"]:::actor
        ClickEnviar["🖥️ Clic en 'Enviar enlace'"]:::actor
        ServiceResetEmail["⚙️ Supabase Auth: resetPasswordForEmail()"]:::service
        ErrorEmailInex{"¿Error: email\nno registrado?"}:::gateway
        ErrorInex["⚠️ Mostrar error: Correo no encontrado"]:::errorNode
        SendEmail["✉️ Enviar correo transaccional de verificación"]:::service
        ShowSuccessReset["🎉 Mostrar alerta: Correo enviado"]:::successNode
        
        %% Redireccion por Email
        ClickLinkEmail["✉️ Usuario hace clic en el enlace del email"]:::actor
        RedirigirReset["🖥️ Redirigir a /reset-password?code=..."]:::client
        InputNewPass["📝 Ingresar y confirmar nueva contraseña"]:::actor
        ClickConfirmReset["🖥️ Clic en 'Guardar contraseña'"]:::actor
        ServiceUpdatePassReset["⚙️ Supabase Auth: updateUser(password)"]:::service
        RedirectLogin["🖥️ Redirigir a /login con mensaje de éxito"]:::successNode
        End_B([🔴 Contraseña restablecida]):::successNode
    end

    Start_A --> AccederPerfil
    AccederPerfil --> CargarDatos
    CargarDatos --> ObtenerDatos
    ObtenerDatos --> RellenarForm
    RellenarForm --> Interaccion
    
    %% Ramificación de Acción 1
    Interaccion -->|"Modificar datos"| ModDatos
    ModDatos --> ClickGuardar
    ClickGuardar --> ValidadorMail
    ValidadorMail -->|"Sí"| ChkDuplicado
    ValidadorMail -->|"No"| UpdateDb
    ChkDuplicado -->|"Sí (Duplicado)"| ErrorDupMail
    ChkDuplicado -->|"No"| UpdateDb
    UpdateDb --> TriggerAudit
    TriggerAudit --> ShowSuccessProfile
    
    %% Ramificación de Acción 2
    Interaccion -->|"Cambiar contraseña"| ModPass
    ModPass --> ClickUpdatePass
    ClickUpdatePass --> VerifyCurrent
    VerifyCurrent -->|"❌ Inválida"| ErrorCurrentPass
    VerifyCurrent -->|"✅ Válida"| UpdateAuthPass
    UpdateAuthPass --> ShowSuccessPass

    %% Flujo B conexiones
    Start_B --> ClickOlvide
    ClickOlvide --> AccederRecuperar
    AccederRecuperar --> IngresarEmail
    IngresarEmail --> ClickEnviar
    ClickEnviar --> ServiceResetEmail
    ServiceResetEmail --> ErrorEmailInex
    ErrorEmailInex -->|"Sí"| ErrorInex
    ErrorEmailInex -->|"No"| SendEmail
    SendEmail --> ShowSuccessReset
    ShowSuccessReset --> ClickLinkEmail
    ClickLinkEmail --> RedirigirReset
    RedirigirReset --> InputNewPass
    InputNewPass --> ClickConfirmReset
    ClickConfirmReset --> ServiceUpdatePassReset
    ServiceUpdatePassReset --> RedirectLogin
    RedirectLogin --> End_B
