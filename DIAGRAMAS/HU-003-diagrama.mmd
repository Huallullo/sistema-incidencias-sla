flowchart TD
    classDef usuario    fill:#dae8fc,stroke:#6c8ebf,color:#000,font-weight:bold
    classDef frontend   fill:#ffe6cc,stroke:#d6b656,color:#000,font-weight:bold
    classDef backend    fill:#e1d5e7,stroke:#9673a6,color:#000,font-weight:bold
    classDef database   fill:#d5e8d4,stroke:#82b366,color:#000,font-weight:bold
    classDef gateway    fill:#fff2cc,stroke:#d6b656,color:#000,font-weight:bold
    classDef errorNode  fill:#f8cecc,stroke:#b85450,color:#000,font-weight:bold
    classDef startEnd   fill:#d5e8d4,stroke:#82b366,color:#000,font-weight:bold

    Start([🟢 INICIO]):::startEnd
    AccederUrl["🖥️ Jefe de TI accede a\n/admin/usuarios"]:::usuario
    Middleware{"¿Sesión activa\ny rol = jefe_ti?"}:::gateway
    RedirigirDashboard["⛔ Redirigir a /dashboard/usuario\n(Mensaje: Acceso Denegado)"]:::errorNode
    End_Denegado([🔴 ACCESO DENEGADO]):::errorNode

    CargarPagina["⚙️ Cargar Página\n(Filtros por defecto: pág 1)"]:::frontend
    LlamarService["⚙️ UsuariosService.getUsers()\n(search, rol, page, limit)"]:::backend
    DbRLS{"¿RLS permite SELECT?\n(public.es_jefe_ti() = true)"}:::gateway
    RetornarVacio["⚠️ Retornar vacío (403)\no denegar acceso"]:::errorNode
    
    DB_Query[("🗄️ SELECT * FROM perfiles\nWITH filters & limit (Supabase)")]:::database
    QueryError{"¿Error en\nla consulta?"}:::gateway
    MostrarError["⚠️ Mostrar alerta:\nError al cargar los usuarios"]:::errorNode
    
    GW_Datos{"¿Existen\nregistros?"}:::gateway
    MostrarMensajeVacio["ℹ️ Mostrar mensaje:\nNo se encontraron usuarios..."]:::frontend
    RenderTabla["🖥️ Renderizar tabla responsiva\n(Nombre, Correo, Rol, Estado)"]:::frontend
    
    Interaccion{"¿Interacción\ndel usuario?"}:::usuario
    BuscarText["📝 Escribir en buscador\n(debounce 300ms)"]:::usuario
    FiltrarRol["Dropdown: Filtrar por Rol\n(Todos/Usuario/Técnico/Jefe)"]:::usuario
    Paginacion["⬅️ Paginación ➡️\n(Cambiar de página)"]:::usuario

    Start --> AccederUrl
    AccederUrl --> Middleware
    Middleware -->|"❌ No"| RedirigirDashboard
    RedirigirDashboard --> End_Denegado
    
    Middleware -->|"✅ Sí"| CargarPagina
    CargarPagina --> LlamarService
    LlamarService --> DbRLS
    DbRLS -->|"❌ No"| RetornarVacio
    DbRLS -->|"✅ Sí"| DB_Query
    
    DB_Query --> QueryError
    QueryError -->|"⚠️ Sí (Error 500/net)"| MostrarError
    QueryError -->|"✅ No"| GW_Datos
    
    GW_Datos -->|"❌ 0 filas"| MostrarMensajeVacio
    GW_Datos -->|"✅ >0 filas"| RenderTabla
    
    RenderTabla --> Interaccion
    MostrarMensajeVacio --> Interaccion
    
    Interaccion --> BuscarText
    Interaccion --> FiltrarRol
    Interaccion --> Paginacion
    
    BuscarText -->|"Filtro search"| LlamarService
    FiltrarRol  -->|"Filtro rol"| LlamarService
    Paginacion  -->|"Filtro rango"| LlamarService
